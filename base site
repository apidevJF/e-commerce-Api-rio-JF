// ─── FORMATAÇÃO ──────────────────────────────────────────────
function formatBRL(v) {
  return 'R$ ' + v.toFixed(2).replace('.', ',');
}
function formatarCEP(v) {
  return v.replace(/\D/g, '').replace(/(\d{5})(\d)/, '$1-$2').slice(0, 9);
}
function calcularParcelas(preco) {
  if (preco < 10) return null;
  const maxParcelas = 12;
  const parcela = preco / maxParcelas;
  if (parcela < 5) {
    const n = Math.floor(preco / 5);
    return `ou ${n}x de ${formatBRL(preco / n)} sem juros`;
  }
  return `ou 12x de ${formatBRL(parcela)} sem juros`;
}

// ─── SISTEMA DE CARRINHO ─────────────────────────────────────
function saveCart() { localStorage.setItem('apijf_cart', JSON.stringify(cart)); }

function addToCart(id, qty) {
  qty = Math.max(1, parseInt(qty) || 1);
  let item = cart.find(i => i.id === id);
  if (item) {
    item.qty += qty;
  } else {
    const p = PRODUTOS.find(p => p.id === id);
    cart.push({ id, qty, nome: p.nome, preco: p.preco, peso: p.peso, imagem: p.imagem });
  }
  saveCart();
  updateCartUI();
  showToast(`${PRODUTOS.find(p => p.id === id).nome} adicionado ao carrinho 🐝`);
}

function removeFromCart(id) {
  cart = cart.filter(i => i.id !== id);
  saveCart();
  updateCartUI();
}

function updateQty(id, delta) {
  const item = cart.find(i => i.id === id);
  if (!item) return;
  item.qty = Math.max(1, item.qty + delta);
  saveCart();
  updateCartUI();
}

function getTotal() { return cart.reduce((s, i) => s + i.preco * i.qty, 0); }
function getTotalPeso() { return cart.reduce((s, i) => s + (i.peso || 1) * i.qty, 0); }
function getCartCount() { return cart.reduce((s, i) => s + i.qty, 0); }

function renderCartContent() {
  const el = document.getElementById('cart-items');
  if (cart.length === 0) {
    el.innerHTML = `
      <div class="cart-empty">
        <div class="cart-empty-icon">🛒</div>
        <p>Seu carrinho está vazio.<br>Adicione produtos para continuar.</p>
        <a href="#produtos" class="btn btn-outline" onclick="closeCart()">Ver produtos</a>
      </div>`;
    return;
  }
  el.innerHTML = cart.map(item => `
    <div class="cart-item" role="listitem">
      <div class="cart-item-img"><img src="${item.imagem}" alt="${item.nome}"></div>
      <div>
        <div class="cart-item-name">${item.nome}</div>
        <div class="cart-item-price">${formatBRL(item.preco)}</div>
        <div class="cart-item-qty">
          <button class="cart-qty-btn" onclick="updateQty(${item.id}, -1)" aria-label="Diminuir quantidade de ${item.nome}">−</button>
          <span class="cart-qty-num" aria-label="Quantidade: ${item.qty}">${item.qty}</span>
          <button class="cart-qty-btn" onclick="updateQty(${item.id}, 1)" aria-label="Aumentar quantidade de ${item.nome}">+</button>
        </div>
        <button class="cart-item-remove" onclick="removeFromCart(${item.id})" aria-label="Remover ${item.nome} do carrinho">✕ Remover</button>
      </div>
      <div class="cart-item-total">${formatBRL(item.preco * item.qty)}</div>
    </div>`).join('');
}

function updateCartUI() {
  renderCartContent();
  document.getElementById('cart-subtotal').textContent = formatBRL(getTotal());
  const count = getCartCount();
  const badge = document.getElementById('cart-count');
  badge.textContent = count;
  badge.classList.toggle('show', count > 0);
}

