const FRETE_REGIOES = {
  MG: { nome: 'Minas Gerais', valor: 18.90, prazo: '3 a 5 dias úteis' },
  SP: { nome: 'São Paulo', valor: 24.90, prazo: '4 a 7 dias úteis' },
  RJ: { nome: 'Rio de Janeiro', valor: 24.90, prazo: '4 a 7 dias úteis' },
  ES: { nome: 'Espírito Santo', valor: 24.90, prazo: '4 a 7 dias úteis' },
  PR: { nome: 'Paraná', valor: 29.90, prazo: '5 a 8 dias úteis' },
  SC: { nome: 'Santa Catarina', valor: 29.90, prazo: '5 a 8 dias úteis' },
  RS: { nome: 'Rio Grande do Sul', valor: 29.90, prazo: '5 a 8 dias úteis' },
  MS: { nome: 'Mato Grosso do Sul', valor: 29.90, prazo: '5 a 8 dias úteis' },
  MT: { nome: 'Mato Grosso', valor: 29.90, prazo: '5 a 8 dias úteis' },
  GO: { nome: 'Goiás', valor: 29.90, prazo: '5 a 8 dias úteis' },
  DF: { nome: 'Distrito Federal', valor: 29.90, prazo: '5 a 8 dias úteis' },
  DEFAULT: { nome: 'Demais regiões', valor: 39.90, prazo: '8 a 12 dias úteis' }
};

function getFreteParaUF(uf) {
  const ufUp = (uf || '').toUpperCase().trim();
  return FRETE_REGIOES[ufUp] || FRETE_REGIOES.DEFAULT;
}

async function consultarViaCEP(cep) {
  const raw = cep.replace(/\D/g, '');
  if (raw.length !== 8) throw new Error('CEP inválido. Informe um CEP com 8 dígitos.');
  const resp = await fetch(`https://viacep.com.br/ws/${raw}/json/`, { signal: AbortSignal.timeout(6000) });
  if (!resp.ok) throw new Error('Falha ao consultar o CEP. Tente novamente.');
  const data = await resp.json();
  if (data.erro) throw new Error('CEP não encontrado. Verifique o número informado.');
  return data;
}

