// ─── AVALIAÇÕES ───────────────────────────────────────────────
function renderAvaliacoes() {
  const container = document.getElementById('lista-avaliacoes');
  const resumo = document.getElementById('avaliacoes-resumo');

  const mediaGeral = getMediaGeralAvaliacoes();
  if (mediaGeral) {
    const starsCompletas = Math.round(mediaGeral.media);
    resumo.innerHTML = `
      <div class="avaliacoes-media-num">${mediaGeral.media.toFixed(1)}</div>
      <div class="avaliacoes-media-info">
        <div class="avaliacoes-media-stars">${'★'.repeat(starsCompletas)}${'☆'.repeat(5 - starsCompletas)}</div>
        <div class="avaliacoes-media-total">${mediaGeral.total} avaliação${mediaGeral.total > 1 ? 'ões' : ''}</div>
      </div>`;
    resumo.style.display = 'flex';
  } else {
    resumo.style.display = 'none';
  }

  if (avaliacoes.length === 0) {
    container.innerHTML = `<div class="card-avaliacao" style="text-align:center;grid-column:1/-1;"><p>Seja o primeiro a avaliar nossos produtos! 🐝</p></div>`;
    return;
  }

  container.innerHTML = avaliacoes.map(a => `
    <div class="card-avaliacao reveal" role="listitem">
      <div class="nome">${escapeHtml(a.nome)}</div>
      <div class="stars" aria-label="${a.estrelas} estrelas">${'★'.repeat(a.estrelas)}${'☆'.repeat(5 - a.estrelas)}</div>
      <div class="comentario">${escapeHtml(a.comentario)}</div>
      <div class="data">${new Date(a.data).toLocaleDateString('pt-BR')}</div>
    </div>`).join('');
  document.querySelectorAll('#lista-avaliacoes .reveal').forEach(el => revealObserver.observe(el));
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

document.getElementById('enviar-avaliacao').addEventListener('click', function () {
  const nome = document.getElementById('nome-avaliacao').value.trim();
  const estrelas = parseInt(document.getElementById('estrelas-avaliacao').value);
  const comentario = document.getElementById('comentario-avaliacao').value.trim();
  if (!nome || !comentario) { showToast('Preencha seu nome e comentário.'); return; }
  avaliacoes.unshift({ nome, estrelas, comentario, data: new Date().toISOString() });
  localStorage.setItem('apijf_avaliacoes', JSON.stringify(avaliacoes));
  renderAvaliacoes();
  renderProdutos();
  document.getElementById('nome-avaliacao').value = '';
  document.getElementById('comentario-avaliacao').value = '';
  showToast('Avaliação enviada! Obrigado 🙏');
});

// ─── TOAST ────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ─── HEADER SCROLL ────────────────────────────────────────────
window.addEventListener('scroll', function () {
  document.getElementById('header').classList.toggle('scrolled', window.scrollY > 40);
  let current = '';
  document.querySelectorAll('section[id]').forEach(s => {
    if (window.scrollY >= s.offsetTop - 120) current = s.id;
  });
  document.querySelectorAll('.nav a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
});

// ─── MENU MOBILE ─────────────────────────────────────────────
document.getElementById('menu-toggle').addEventListener('click', function () {
  const nav = document.getElementById('main-nav');
  const isOpen = nav.classList.toggle('open');
  this.setAttribute('aria-expanded', isOpen);
});
document.querySelectorAll('#main-nav a').forEach(a => {
  a.addEventListener('click', function () {
    document.getElementById('main-nav').classList.remove('open');
    document.getElementById('menu-toggle').setAttribute('aria-expanded', 'false');
  });
});

// ─── ESC fecha modais ────────────────────────────────────────
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape') {
    if (document.getElementById('checkout-overlay').classList.contains('open')) { fecharCheckout(); return; }
    if (document.getElementById('modal-produto').classList.contains('open')) { fecharModalProduto(); return; }
    if (document.getElementById('cart-sidebar').classList.contains('open')) { closeCart(); return; }
  }
});

// ─── REVEAL ON SCROLL ────────────────────────────────────────
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.08 });

function ativarReveal() {
  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
}

// ─── INICIALIZAÇÃO ────────────────────────────────────────────
renderProdutos();
updateCartUI();
renderAvaliacoes();
ativarReveal();
</script>
</body>
</html>