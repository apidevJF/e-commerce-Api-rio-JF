}

// ─── RENDERIZAR PRODUTOS ──────────────────────────────────────
function getMediaAvaliacao(produtoId) {
  const revs = avaliacoes.filter(a => a.produtoId === produtoId);
  if (!revs.length) return null;
  const media = revs.reduce((s, a) => s + a.estrelas, 0) / revs.length;
  return { media: Math.round(media * 10) / 10, total: revs.length };
}

function getMediaGeralAvaliacoes() {
  if (!avaliacoes.length) return null;
  const media = avaliacoes.reduce((s, a) => s + a.estrelas, 0) / avaliacoes.length;
  return { media: Math.round(media * 10) / 10, total: avaliacoes.length };
}

function produtoMatchFiltro(p) {
  const cat = p.categoria.toLowerCase();
  if (filtroAtivo === 'todos') return true;
  if (filtroAtivo === 'cera') return cat === 'cera' || cat === 'apicultura';
  if (filtroAtivo === 'propolis') return cat === 'própolis' || cat === 'saude' || cat === 'saúde';
  if (filtroAtivo === 'bebidas') return cat === 'bebidas';
  if (filtroAtivo === 'kits') return cat === 'kits';
  if (filtroAtivo === 'equipamentos') return cat === 'equipamentos';
  return true;
}

function produtoMatchBusca(p) {
  if (!buscaAtiva) return true;
  const q = buscaAtiva.toLowerCase();
  return (
    p.nome.toLowerCase().includes(q) ||
    p.categoria.toLowerCase().includes(q) ||
    p.desc.toLowerCase().includes(q) ||
    (p.descCompleta && p.descCompleta.toLowerCase().includes(q))
  );
}

function renderProdutos() {
  const grid = document.getElementById('produtos-grid');
  const filtrados = PRODUTOS.filter(p => produtoMatchFiltro(p) && produtoMatchBusca(p));

  if (filtrados.length === 0) {
    grid.innerHTML = `<div class="produtos-vazio"><p>🔍 Nenhum produto encontrado para "<strong>${buscaAtiva || filtroAtivo}</strong>".<br>Tente outro termo ou filtro.</p></div>`;
    return;
  }

  grid.innerHTML = filtrados.map(p => {
    const avaliacao = getMediaAvaliacao(p.id);
    const parcelas = calcularParcelas(p.preco);
    return `
      <div class="produto-card reveal" role="listitem">
        <div class="produto-img" onclick="abrirModalProduto(${p.id})" role="button" tabindex="0" aria-label="Ver detalhes de ${p.nome}" onkeydown="if(event.key==='Enter')abrirModalProduto(${p.id})">
          ${p.badge ? `<span class="badge-promo">${p.badge}</span>` : ''}
          <img src="${p.imagem}" alt="${p.nome}">
          <div class="produto-img-overlay"><span>Ver detalhes</span></div>
        </div>
        <div class="produto-body">
          <div class="produto-category">${p.categoria}</div>
          <h3 class="produto-nome" onclick="abrirModalProduto(${p.id})" role="button" tabindex="0" onkeydown="if(event.key==='Enter')abrirModalProduto(${p.id})">${p.nome}</h3>
          ${avaliacao ? `
            <div class="produto-avaliacao-mini">
              <span class="produto-stars-mini">${'★'.repeat(Math.round(avaliacao.media))}${'☆'.repeat(5 - Math.round(avaliacao.media))}</span>
              <span class="produto-reviews-count">${avaliacao.media} (${avaliacao.total})</span>
            </div>` : ''}
          <p class="produto-desc">${p.desc}</p>
          <div class="produto-preco-wrap">
            ${p.precoAnterior ? `<div class="produto-preco-de">De: ${formatBRL(p.precoAnterior)}</div>` : ''}
            <div class="produto-preco">${formatBRL(p.preco)}</div>
            ${parcelas ? `<div class="produto-parcela">${parcelas}</div>` : ''}
          </div>
          <div class="produto-footer">
            <div class="qty-control" role="group" aria-label="Quantidade">
